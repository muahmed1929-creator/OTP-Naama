{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@otp-saas/db": ["packages/db/index.ts"],
      "@otp-saas/queue": ["packages/queue/index.ts"],
      "@otp-saas/api": ["apps/api/src/index.ts"]
    },
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}
